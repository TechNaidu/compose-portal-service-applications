{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ECRLogin",
      "Effect": "Allow",
      "Action": "ecr:GetAuthorizationToken",
      "Resource": "*"
    },
    {
      "Sid": "ECRPushPullAllMicroservices",
      "Effect": "Allow",
      "Action": [
        "ecr:BatchCheckLayerAvailability",
        "ecr:GetDownloadUrlForLayer",
        "ecr:BatchGetImage",
        "ecr:PutImage",
        "ecr:InitiateLayerUpload",
        "ecr:UploadLayerPart",
        "ecr:CompleteLayerUpload",
        "ecr:DescribeRepositories",
        "ecr:DescribeImages",
        "ecr:ListImages"
      ],
      "Resource": [
        "arn:aws:ecr:us-east-1:123456789012:repository/compose-portal-gateway",
        "arn:aws:ecr:us-east-1:123456789012:repository/compose-portal-user",
        "arn:aws:ecr:us-east-1:123456789012:repository/compose-portal-product",
        "arn:aws:ecr:us-east-1:123456789012:repository/compose-portal-order"
      ]
    },
    {
      "Sid": "DenyECRDelete",
      "Effect": "Deny",
      "Action": [
        "ecr:DeleteRepository",
        "ecr:BatchDeleteImage",
        "ecr:DeleteLifecyclePolicy"
      ],
      "Resource": "*"
    }
  ]
}

