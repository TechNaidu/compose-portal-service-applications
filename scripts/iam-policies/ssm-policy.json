{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SSMReadWrite",
      "Effect": "Allow",
      "Action": [
        "ssm:PutParameter",
        "ssm:GetParameter",
        "ssm:GetParameters",
        "ssm:GetParametersByPath",
        "ssm:DescribeParameters",
        "ssm:AddTagsToResource"
      ],
      "Resource": [
        "arn:aws:ssm:us-east-1:123456789012:parameter/compose-portal/prod/*",
        "arn:aws:ssm:us-east-1:123456789012:parameter/compose-portal/staging/*",
        "arn:aws:ssm:us-east-1:123456789012:parameter/compose-portal/*"
      ]
    },
    {
      "Sid": "DenySSMDeleteProd",
      "Effect": "Deny",
      "Action": [
        "ssm:DeleteParameter",
        "ssm:DeleteParameters"
      ],
      "Resource": "arn:aws:ssm:us-east-1:123456789012:parameter/compose-portal/prod/*"
    }
  ]
}

